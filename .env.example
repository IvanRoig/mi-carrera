# Credenciales de Supabase (auth + almacenamiento en la nube).
# Copiá este archivo a `.env.local` y completá con los datos de TU proyecto.
# .env.local está gitignoreado: no se sube al repo.
#
# La anon key es PÚBLICA por diseño (segura de exponer en el front): los datos
# están protegidos por Row-Level Security. Si dejás estas vacías, la app corre
# en modo invitado (solo localStorage), sin cuentas.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
